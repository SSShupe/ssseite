{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Write(content/**)",
      "Write(templates/**)",
      "Write(static/**)",
      "Write(data/**)",
      "Edit(content/**)",
      "Edit(templates/**)",
      "Edit(data/**)",
      "Bash(seite build:*)",
      "Bash(seite build)",
      "Bash(seite new:*)",
      "Bash(seite serve:*)",
      "Bash(seite theme:*)",
      "Glob",
      "Grep",
      "WebSearch"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "mcpServers": {
    "seite": {
      "command": "seite",
      "args": ["mcp"]
    }
  }
}
